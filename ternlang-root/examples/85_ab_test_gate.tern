// ─────────────────────────────────────────────────────────────────────────────
// 85_ab_test_gate.tern — A/B test significance gate
//
// Binary A/B test analysis often calls a winner too early. Ternary logic
// uses 'hold' to mean "Not enough statistical power, continue running,"
// actively preventing p-hacking.
//   +1: Winner declared
//    0: Continue collecting data (Hold)
//   -1: Loser / Stop test
// ─────────────────────────────────────────────────────────────────────────────

fn p_value(p: trit) -> trit { return p; }
fn sample_size(size: trit) -> trit { return size; }
fn effect_size(effect: trit) -> trit { return effect; }

fn ab_test_eval(p: trit, size: trit, effect: trit) -> trit {
    match size {
        -1 => { return hold(); } // Too few samples to decide anything
         0 => { return hold(); }
         1 => {
             // Adequate sample size.
             match p {
                 -1 => { return hold(); } // Not statistically significant yet
                  0 => { return hold(); }
                  1 => {
                      match effect {
                          -1 => { return conflict(); } // Significant, but effect is NEGATIVE (Loser)
                           0 => { return hold(); }     // Significant, but effect is tiny. Keep running.
                           1 => { return truth(); }    // Significant and positive (Winner)
                      }
                  }
             }
         }
    }
}

let stat_p: trit = truth();
let stat_size: trit = truth();
let stat_effect: trit = conflict(); // Conversions dropped by 10%

let test_action: trit = ab_test_eval(stat_p, stat_size, stat_effect);

match test_action {
    -1 => { return conflict(); }   // LOSER: Revert to control immediately
     0 => { return hold();    }   // CONTINUE: Keep test running
     1 => { return truth();   }   // WINNER: Roll out variant to 100%
}
