// ─────────────────────────────────────────────────────────────────────────────
// 129_feature_flag_rollout.tern — Feature Flag Rollout Control
//
// Binary logic fails by forcing a choice between two extremes. 
// Ternary logic: Adds 'canary' for percentage-based traffic steering.
//   +1: DISABLE
//    0: CANARY
//   -1: ENABLE
// ─────────────────────────────────────────────────────────────────────────────

fn check_global(x: trit) -> trit { return x; }
fn check_group(x: trit) -> trit { return x; }
fn check_threshold(x: trit) -> trit { return x; }

fn main_logic(global: trit, group: trit, threshold: trit) -> trit {
    match global {
        1 => { return truth(); }
        -1 => {
            match threshold {
                1 => { return truth(); }
                0 => { return hold(); }
                -1 => { return invert(truth()); }
            }
        }
        0 => { return hold(); }
    }
}

// ── Concrete scenario: Global switch off, but errors are starting to spike in canary. ──
let s_0: trit = invert(truth());
let s_1: trit = truth();
let s_2: trit = hold();

let outcome: trit = main_logic(s_0, s_1, s_2);

match outcome {
    1 => { return truth(); }    // DISABLE
    0 => { return hold();  }    // CANARY
   -1 => { return invert(truth()); } // ENABLE
}
