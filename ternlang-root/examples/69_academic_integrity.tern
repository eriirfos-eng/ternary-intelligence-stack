// ─────────────────────────────────────────────────────────────────────────────
// 69_academic_integrity.tern — Academic integrity flag
//
// Plagiarism checkers output a binary percentage, leading to false accusations
// over common phrases. A ternary system uses 'hold' for "Schedule a verbal
// defense with the student," recognizing that software cannot prove intent.
//   +1: Original work
//    0: Suspicious (Schedule verbal defense)
//   -1: Blatant copying / Contract cheating
// ─────────────────────────────────────────────────────────────────────────────

fn text_overlap(overlap: trit) -> trit { return overlap; }
fn stylometric_shift(style: trit) -> trit { return style; }
fn metadata_anomaly(meta: trit) -> trit { return meta; }

fn integrity_check(overlap: trit, style: trit, meta: trit) -> trit {
    let AI_suspicion: trit = consensus(style, meta);
    
    // Direct copy-paste of existing text is hard to dispute
    match overlap {
        -1 => { return conflict(); } // 80%+ match to Wikipedia.
         0 => {
             // 20% overlap. Could be quotes/citations. Check style.
             match AI_suspicion {
                 -1 => { return hold(); }    // Minor overlap but completely different writing style
                  0 => { return hold(); }
                  1 => { return truth(); }   // Minor overlap, but style is consistent with past work
             }
         }
         1 => {
             // No direct overlap. Did they buy the essay or use an LLM?
             match AI_suspicion {
                 -1 => { return hold(); }    // Total stylometric shift. Ask them to explain the concepts.
                  0 => { return hold(); }
                  1 => { return truth(); }   // Original and consistent
             }
         }
    }
}

// ── Concrete scenario with realistic values ──
let similarity_score: trit = truth();  // 2% overlap, totally fine
let author_style: trit = conflict();   // Reads like a PhD thesis, student is a freshman
let doc_metadata: trit = hold();       // Edited for exactly 3 minutes

let integrity_action: trit = integrity_check(similarity_score, author_style, doc_metadata);

// Expected result: hold() - AI suspicion consensus is hold. Call them in.
match integrity_action {
    -1 => { return conflict(); }   // REPORT: Forward to Academic Honor Council
     0 => { return hold();    }   // INQUIRE: Professor requests a 10-minute verbal defense
     1 => { return truth();   }   // GRADE: Proceed to normal grading
}
