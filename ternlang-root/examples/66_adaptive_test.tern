// ─────────────────────────────────────────────────────────────────────────────
// 66_adaptive_test.tern — Adaptive test difficulty gate
//
// Binary testing logic either passes or fails a student. Ternary adaptive testing
// introduces 'hold' to mean "Repeat the concept with a different question."
// It actively tries to build confidence rather than just categorizing the student
// as failing.
//   +1: Advance to harder topic
//    0: Repeat concept / Different question (Hold)
//   -1: Remediate / Drop difficulty
// ─────────────────────────────────────────────────────────────────────────────

fn time_to_answer(time: trit) -> trit { return time; }
fn answer_correctness(correct: trit) -> trit { return correct; }
fn previous_concept_score(prev: trit) -> trit { return prev; }

fn adaptive_logic(time: trit, correct: trit, prev: trit) -> trit {
    // Correctness is the most important factor
    match correct {
        -1 => {
            // Wrong answer. Did they guess quickly or struggle?
            match time {
                -1 => { return hold(); }     // Answered instantly (guessed). Give them another chance.
                 0 => { return conflict(); } // Struggled and still got it wrong -> Remediate
                 1 => { return conflict(); } // Took a long time, got it wrong -> Remediate
            }
        }
         0 => { return hold(); } // Partial credit. Repeat concept.
         1 => {
             // Correct answer. Check if they are confident.
             match time {
                 -1 => { return truth(); }   // Instantly correct. Advance.
                  0 => { return hold(); }    // Took a moderate amount of time. Give one more to be sure.
                  1 => { return hold(); }    // Took a very long time. They know it, but aren't fluent.
             }
         }
    }
}

// ── Concrete scenario with realistic values ──
let answer_time: trit = hold();      // Took 45 seconds (average)
let student_answer: trit = truth();  // Correct answer chosen
let prev_score: trit = hold();       // Previous questions were mixed

let next_question: trit = adaptive_logic(answer_time, student_answer, prev_score);

// Expected result: hold() - Correct, but took a while. Give them another similar question.
match next_question {
    -1 => { return conflict(); }   // REMEDIATE: Show tutorial video, lower difficulty
     0 => { return hold();    }   // REPEAT: Generate a peer question at the same difficulty
     1 => { return truth();   }   // ADVANCE: Increase difficulty level
}
