{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Ternlang",
  "scopeName": "source.ternlang",
  "patterns": [
    { "include": "#comments" },
    { "include": "#directives" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#trit-literals" },
    { "include": "#string-literals" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.ternlang",
          "match": "//.*$"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "meta.preprocessor.ternlang",
          "match": "@(sparseskip|print|print_tensor)\\b",
          "captures": {
            "0": { "name": "keyword.control.directive.ternlang" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ternlang",
          "match": "\\b(if|else|match|return|for|in|while|loop|break|continue)\\b"
        },
        {
          "name": "keyword.declaration.ternlang",
          "match": "\\b(fn|let|mut|use|pub|mod|struct|agent)\\b"
        },
        {
          "name": "keyword.operator.actor.ternlang",
          "match": "\\b(spawn|send|await|remote|nodeid)\\b"
        },
        {
          "name": "keyword.other.ternlang",
          "match": "\\b(cast|consensus|invert|truth|hold|conflict|matmul|sparsity|shape)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.ternlang",
          "match": "\\b(trit|trittensor|int|float|bool|string|agentref)\\b"
        },
        {
          "comment": "trittensor<N x M> generic",
          "name": "storage.type.tensor.ternlang",
          "match": "trittensor<[^>]*>"
        }
      ]
    },
    "trit-literals": {
      "patterns": [
        {
          "comment": "Ternary literals: -1, 0, 1 — coloured distinctly from ordinary numbers",
          "name": "constant.language.trit.truth.ternlang",
          "match": "(?<![a-zA-Z0-9_])\\b1\\b(?![a-zA-Z0-9_])"
        },
        {
          "name": "constant.language.trit.hold.ternlang",
          "match": "(?<![a-zA-Z0-9_])\\b0\\b(?![a-zA-Z0-9_])"
        },
        {
          "name": "constant.language.trit.conflict.ternlang",
          "match": "(?<![a-zA-Z0-9_])-1\\b(?![a-zA-Z0-9_])"
        }
      ]
    },
    "string-literals": {
      "patterns": [
        {
          "name": "string.quoted.double.ternlang",
          "begin": "\"",
          "end": "\"",
          "patterns": []
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.ternlang",
          "match": "\\b[2-9][0-9]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.ternlang",
          "match": "(==|!=|=>|->|::|&&|\\|\\||\\+|-|\\*|=|\\?|@)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "comment": "Function call: ident(",
          "name": "entity.name.function.ternlang",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "comment": "Type names start with uppercase",
          "name": "entity.name.type.ternlang",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "variable.other.ternlang",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
